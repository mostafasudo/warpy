{
  "family": "warpy-prod-worker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "",
  "containerDefinitions": [
    {
      "name": "warpy-prod-worker",
      "image": "",
      "essential": true,
      "command": [
        "sh",
        "-c",
        "rq worker default --url \"$REDIS_URL\" --worker-class app.workers.no_client_list_worker.NoClientListWorker"
      ],
      "environment": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/warpy-prod-worker",
          "awslogs-region": "",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "volumes": []
}
